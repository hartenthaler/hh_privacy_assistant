<?php

declare(strict_types=1);

use Fisharebest\Webtrees\I18N;
use Hartenthaler\Webtrees\Module\PrivacyAssistant\Internationalization\MoreI18N;

/**
 * @var string $title
 * @var string $description
 * @var int $retentionYears
 * @var string $lastScan
 * @var int $lastExpiredCount
 * @var int $lastRetentionYears
 * @var list<array{id:int,userName:string,realName:string,email:string,registered:string,lastActivity:string,inactiveDays:int,isAdmin:bool}> $expiredAccounts
 * @var string $legalNoticeConfigLink
 * @var array{registrationEnabled:bool,cautionEnabled:bool,perUserConsentStored:bool} $registrationConsentStatus
 * @var string $siteRegistrationConfigLink
 * @var array<string,string> $treeOptions
 * @var string $selectedProtectionTree
 * @var int $releaseYears
 * @var list<array{xref:string,name:string,url:string,lifespan:string,pattern:string,fact:string,deathStatus:string,action:string,changed:bool}> $protectionResult
 * @var bool $protectionApplied
 * @var bool $protectionSubmitted
 */
?>

<h1><?= e($title) ?></h1>
<p><?= e($description) ?></p>

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h4"><?= I18N::translate('Inactive user accounts') ?></h2>

        <?php if ($retentionYears === 0) : ?>
            <p>
                <?= I18N::translate('No retention period for inactive user accounts is currently configured. The assistant therefore does not report accounts as overdue.') ?>
            </p>
        <?php else : ?>
            <p>
                <?= I18N::plural('The privacy policy currently states that inactive user accounts are deleted after %s year.', 'The privacy policy currently states that inactive user accounts are deleted after %s years.', $retentionYears, I18N::number($retentionYears)) ?>
            </p>
            <p>
                <?= I18N::plural('%s user account has reached or exceeded this retention period.', '%s user accounts have reached or exceeded this retention period.', count($expiredAccounts), I18N::number(count($expiredAccounts))) ?>
            </p>
        <?php endif ?>

        <dl class="row mb-0">
            <dt class="col-sm-3"><?= I18N::translate('Retention setting') ?></dt>
            <dd class="col-sm-9">
                <?php if ($retentionYears === 0) : ?>
                    <?= I18N::translate('never') ?>
                <?php else : ?>
                    <?= I18N::plural('%s year', '%s years', $retentionYears, I18N::number($retentionYears)) ?>
                <?php endif ?>
                <a class="ms-2" href="<?= e($legalNoticeConfigLink) ?>"><?= I18N::translate('Change in legal notice module') ?></a>
            </dd>

            <dt class="col-sm-3"><?= I18N::translate('Last scan') ?></dt>
            <dd class="col-sm-9"><?= $lastScan === '' ? I18N::translate('not yet') : e($lastScan) ?></dd>

            <dt class="col-sm-3"><?= I18N::translate('Last scan result') ?></dt>
            <dd class="col-sm-9">
                <?= I18N::plural('%s overdue account', '%s overdue accounts', $lastExpiredCount, I18N::number($lastExpiredCount)) ?>
                <?php if ($lastRetentionYears !== $retentionYears) : ?>
                    <span class="text-muted">
                        <?= I18N::translate('The retention setting has changed since the last scan.') ?>
                    </span>
                <?php endif ?>
            </dd>
        </dl>
    </div>
</div>

<?php if ($expiredAccounts !== []) : ?>
    <table class="table table-bordered table-sm wt-table-menu">
        <thead>
            <tr>
                <th><?= I18N::translate('User name') ?></th>
                <th><?= MoreI18N::xlate('Real name') ?></th>
                <th><?= I18N::translate('E-mail') ?></th>
                <th><?= I18N::translate('Registered') ?></th>
                <th><?= I18N::translate('Last login') ?></th>
                <th class="text-end"><?= I18N::translate('Inactive days') ?></th>
                <th><?= MoreI18N::xlate('Notes') ?></th>
            </tr>
        </thead>
        <tbody>
            <?php foreach ($expiredAccounts as $account) : ?>
                <tr>
                    <td><?= e($account['userName']) ?></td>
                    <td><?= e($account['realName']) ?></td>
                    <td><?= e($account['email']) ?></td>
                    <td><?= e($account['registered']) ?></td>
                    <td><?= e($account['lastActivity']) ?></td>
                    <td class="text-end"><?= I18N::number($account['inactiveDays']) ?></td>
                    <td>
                        <?php if ($account['isAdmin']) : ?>
                            <span class="badge bg-warning text-dark"><?= I18N::translate('administrator') ?></span>
                        <?php endif ?>
                    </td>
                </tr>
            <?php endforeach ?>
        </tbody>
    </table>
<?php endif ?>

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h4"><?= I18N::translate('Self-registration and acceptable use agreement') ?></h2>

        <p>
            <?= I18N::translate('This check distinguishes between the current global registration settings and proof that a specific user accepted the terms during self-registration.') ?>
        </p>

        <dl class="row mb-0">
            <dt class="col-sm-4"><?= I18N::translate('Visitors can request a new user account') ?></dt>
            <dd class="col-sm-8">
                <?php if ($registrationConsentStatus['registrationEnabled']) : ?>
                    <span class="badge bg-success"><?= I18N::translate('yes') ?></span>
                <?php else : ?>
                    <span class="badge bg-secondary"><?= I18N::translate('no') ?></span>
                <?php endif ?>
            </dd>

            <dt class="col-sm-4"><?= I18N::translate('Acceptable use agreement is shown during self-registration') ?></dt>
            <dd class="col-sm-8">
                <?php if ($registrationConsentStatus['cautionEnabled']) : ?>
                    <span class="badge bg-success"><?= I18N::translate('yes') ?></span>
                <?php else : ?>
                    <span class="badge bg-warning text-dark"><?= I18N::translate('no') ?></span>
                <?php endif ?>
                <a class="ms-2" href="<?= e($siteRegistrationConfigLink) ?>"><?= I18N::translate('Change in webtrees sign-in and registration settings') ?></a>
            </dd>

            <dt class="col-sm-4"><?= I18N::translate('Per-user acceptance record') ?></dt>
            <dd class="col-sm-8">
                <?php if ($registrationConsentStatus['perUserConsentStored']) : ?>
                    <span class="badge bg-success"><?= I18N::translate('available') ?></span>
                <?php else : ?>
                    <span class="badge bg-warning text-dark"><?= I18N::translate('not available') ?></span>
                <?php endif ?>
            </dd>
        </dl>

        <?php if ($registrationConsentStatus['registrationEnabled'] && !$registrationConsentStatus['cautionEnabled']) : ?>
            <div class="alert alert-warning mt-3 mb-0">
                <?= I18N::translate('Self-registration is enabled, but the acceptable use agreement is not shown. New users can request an account without seeing this privacy-related notice.') ?>
            </div>
        <?php elseif (!$registrationConsentStatus['registrationEnabled']) : ?>
            <div class="alert alert-info mt-3 mb-0">
                <?= I18N::translate('Self-registration is disabled. The acceptable use agreement is therefore not part of the current registration workflow.') ?>
            </div>
        <?php endif ?>

        <?php if (!$registrationConsentStatus['perUserConsentStored']) : ?>
            <div class="alert alert-info mt-3 mb-0">
                <?= I18N::translate('webtrees currently shows the acceptable use agreement as notice text only. It does not store a separate, audit-proof acceptance record for each registered user.') ?>
                <?= I18N::translate('For audit-proof documentation, webtrees would need to store the exact text, version, timestamp, and user account for each acceptance.') ?>
            </div>
        <?php endif ?>
    </div>
</div>

<div class="card mb-3">
    <div class="card-body">
        <h2 class="h4"><?= I18N::translate('Sensitive information') ?></h2>

        <p>
            <?= I18N::translate('Sensitive facts can be protected with RESN CONFIDENTIAL until the person has been dead for the configured number of years.') ?>
        </p>

        <form method="post" class="row gy-3">
            <?= csrf_field() ?>

            <div class="col-md-5">
                <label class="form-label" for="protectionTree"><?= I18N::translate('Family tree') ?></label>
                <?= view('components/select', [
                    'id' => 'protectionTree',
                    'name' => 'protectionTree',
                    'options' => $treeOptions,
                    'selected' => $selectedProtectionTree,
                ]) ?>
            </div>

            <div class="col-md-3">
                <label class="form-label" for="releaseYears"><?= I18N::translate('Release after death') ?></label>
                <input class="form-control" id="releaseYears" name="releaseYears" type="number" min="0" max="150" value="<?= e((string) $releaseYears) ?>">
            </div>

            <div class="col-md-4 d-flex align-items-end gap-2">
                <button class="btn btn-secondary" type="submit" name="task" value="preview">
                    <?= I18N::translate('Preview') ?>
                </button>
                <button class="btn btn-primary" type="submit" name="task" value="apply">
                    <?= I18N::translate('Apply changes') ?>
                </button>
            </div>
        </form>

        <?php if ($protectionSubmitted && $protectionResult === []) : ?>
            <p class="mt-4 mb-0">
                <?= I18N::translate('No matching sensitive facts were found in the selected tree.') ?>
            </p>
        <?php elseif ($protectionResult !== []) : ?>
            <h3 class="h5 mt-4">
                <?php if ($protectionApplied) : ?>
                    <?= I18N::translate('Applied changes') ?>
                <?php else : ?>
                    <?= I18N::translate('Preview result') ?>
                <?php endif ?>
            </h3>

            <table class="table table-bordered table-sm wt-table-sensitive-information datatables d-none"
                <?= view('lists/datatables-attributes') ?>
                data-sorting="<?= e('[[ 4, "asc" ]]') ?>"
            >
                <thead>
                    <tr>
                        <th><?= I18N::translate('Individual') ?></th>
                        <th><?= I18N::translate('Pattern') ?></th>
                        <th><?= I18N::translate('Fact') ?></th>
                        <th><?= I18N::translate('Death status') ?></th>
                        <th><?= I18N::translate('Action') ?></th>
                    </tr>
                </thead>
                <tbody>
                    <?php foreach ($protectionResult as $row) : ?>
                        <tr>
                            <td data-sort="<?= e(strip_tags($row['name'])) ?>">
                                <a href="<?= e($row['url']) ?>"><?= $row['name'] ?></a>
                                <?php if ($row['lifespan'] !== '') : ?>
                                    <span class="text-muted"><?= e($row['lifespan']) ?></span>
                                <?php endif ?>
                            </td>
                            <td data-sort="<?= e($row['pattern']) ?>"><?= e($row['pattern']) ?></td>
                            <td><code><?= e($row['fact']) ?></code></td>
                            <td><?= e($row['deathStatus']) ?></td>
                            <td data-sort="<?= e($row['action']) ?>">
                                <?php if ($row['action'] === 'add') : ?>
                                    <?= $protectionApplied ? I18N::translate('RESN CONFIDENTIAL added') : I18N::translate('RESN CONFIDENTIAL would be added') ?>
                                <?php elseif ($row['action'] === 'remove') : ?>
                                    <?= $protectionApplied ? I18N::translate('RESN CONFIDENTIAL removed') : I18N::translate('RESN CONFIDENTIAL would be removed') ?>
                                <?php else : ?>
                                    <?= I18N::translate('unchanged') ?>
                                <?php endif ?>
                            </td>
                        </tr>
                    <?php endforeach ?>
                </tbody>
            </table>
        <?php endif ?>
    </div>
</div>

<p class="small text-muted">
    <?= I18N::translate('The assistant reports privacy and security findings for administrative review. It does not delete accounts automatically, and GEDCOM facts are changed only after confirmation.') ?>
</p>
